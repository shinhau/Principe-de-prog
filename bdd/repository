def get_student_by_id(student_id):
    conn = get_connection()
    cursor = conn.cursor(dictionary=True)

    query = "SELECT * FROM students WHERE id = %s"

    cursor.execute(query,(student_id,))

    student = cursor.fetchone()

    cursor.close()
    conn.close()

    return student

